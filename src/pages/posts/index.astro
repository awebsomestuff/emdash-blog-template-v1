---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";

const cursor = Astro.url.searchParams.get("cursor") ?? undefined;

const { entries: posts, nextCursor, cacheHint } = await getEmDashCollection("posts", {
	limit: 12,
	cursor,
	orderBy: { published_at: "desc" },
});
Astro.cache.set(cacheHint);
---
<Base title="All Posts" description="Browse all articles">
	<div class="archive-header">
		<h1>All Posts</h1>
		<p>Explore all our articles and stories</p>
	</div>

	{posts.length === 0 ? (
		<section class="empty-state">
			<h2>No posts yet</h2>
			<p>Create your first post in the admin panel.</p>
			<a href="/_emdash/admin/content/posts/new">Create a post</a>
		</section>
	) : (
		<>
			<div class="posts-grid">
				{posts.map(post => (
					<PostCard post={post} />
				))}
			</div>

			{nextCursor && (
				<div class="pagination">
					<a href={`?cursor=${nextCursor}`}>Load more posts &rarr;</a>
				</div>
			)}
		</>
	)}
</Base>
