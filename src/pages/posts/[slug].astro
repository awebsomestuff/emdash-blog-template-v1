---
import { getEmDashEntry, getEntryTerms, getSeoMeta, getSiteSettings } from "emdash";
import { Image, PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import TagList from "../../components/TagList.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import RelatedPosts from "../../components/RelatedPosts.astro";
import { getReadingTime } from "../../utils/reading-time";

const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);
if (!post) return Astro.redirect("/404");

Astro.cache.set(cacheHint);

const settings = await getSiteSettings();
const siteTitle = settings?.title || "Blog Pro";

const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
});

const tags = await getEntryTerms("posts", post.data.id, "tag");
const categories = await getEntryTerms("posts", post.data.id, "category");
const readingTime = getReadingTime(post.data.content);

const publishedDate = post.data.publishedAt?.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---
<Base
	title={seo.title}
	description={seo.description}
	image={seo.ogImage}
	content={{ collection: "posts", id: post.data.id, slug }}
>
	<article>
		<header class="post-header">
			{categories.length > 0 && (
				<a href={`/category/${categories[0].slug}`} class="post-card-category" style="margin-bottom: var(--space-md); display: inline-block;">
					{categories[0].label}
				</a>
			)}
			<h1 {...post.edit.title}>{post.data.title}</h1>
			<div class="post-header-meta">
				{post.data.byline && <span>{post.data.byline.displayName}</span>}
				{publishedDate && (
					<>
						<span class="separator"></span>
						<span>{publishedDate}</span>
					</>
				)}
				<span class="separator"></span>
				<span>{readingTime} min read</span>
			</div>
		</header>

		{post.data.featured_image && (
			<div class="post-hero-image" {...post.edit.featured_image}>
				<Image image={post.data.featured_image} />
			</div>
		)}

		<div class="post-layout">
			<div class="prose">
				<PortableText value={post.data.content} />

				{tags.length > 0 && (
					<div style="margin-top: var(--space-2xl);">
						<TagList tags={tags} />
					</div>
				)}
			</div>

			<aside>
				<TableOfContents content={post.data.content} />
			</aside>
		</div>

		<RelatedPosts currentPostId={post.id} currentPostDataId={post.data.id} />
	</article>
</Base>
