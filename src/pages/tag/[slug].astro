---
import { getTerm, getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";

const { slug } = Astro.params;
const term = slug ? await getTerm("tag", slug) : null;
if (!term) return Astro.redirect("/404");

const cursor = Astro.url.searchParams.get("cursor") ?? undefined;

const { entries: posts, nextCursor, cacheHint } = await getEmDashCollection("posts", {
	where: { tag: term.slug },
	orderBy: { published_at: "desc" },
	limit: 12,
	cursor,
});
Astro.cache.set(cacheHint);
---
<Base title={`#${term.label}`} description={`Posts tagged with ${term.label}`}>
	<div class="archive-header">
		<h1>#{term.label}</h1>
		<p>All posts with this tag</p>
	</div>

	{posts.length === 0 ? (
		<section class="empty-state">
			<h2>No posts with this tag yet</h2>
			<a href="/posts">Browse all posts</a>
		</section>
	) : (
		<>
			<div class="posts-grid">
				{posts.map(post => (
					<PostCard post={post} />
				))}
			</div>

			{nextCursor && (
				<div class="pagination">
					<a href={`?cursor=${nextCursor}`}>Load more &rarr;</a>
				</div>
			)}
		</>
	)}
</Base>
